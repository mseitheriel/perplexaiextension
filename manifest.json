{
  "manifest_version": 3,
  "name": "Perplexity Rate Limit Monitor",
  "version": "1.0.0",
  "description": "Monitor your Perplexity AI rate limits and usage at a glance.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "https://www.perplexity.ai/*"
  ]
}
